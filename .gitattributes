# Default: text files normalize to LF in repo, LF in working tree.
# This makes upstream rebases survive CRLF/LF line-ending differences cleanly.
* text=auto eol=lf

# Compiled binaries / object files
*.dll   binary
*.exe   binary
*.so    binary
*.so.*  binary
*.dylib binary
*.a     binary
*.lib   binary
*.o     binary
*.obj   binary
*.pdb   binary

# Images
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.bmp  binary
*.tga  binary
*.pcx  binary
*.ico  binary
*.icns binary

# Audio / video
*.wav binary
*.ogg binary
*.mp3 binary
*.mp4 binary
*.smk binary

# Archives
*.zip binary
*.tar binary
*.tgz binary
*.gz  binary
*.bz2 binary
*.xz  binary
*.7z  binary

# Quake-derived game asset formats
*.pak binary
*.bsp binary
*.md2 binary
*.md3 binary
*.fm  binary
*.sp2 binary
*.wal binary

# Fonts / docs
*.ttf binary
*.otf binary
*.pdf binary
